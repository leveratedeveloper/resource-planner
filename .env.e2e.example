# Copy this file to .env.e2e.local and fill values before running Playwright tests.
# Do not commit .env.e2e.local.

# Required for all local/CI E2E runs
E2E_PROJECT_ID=
DATABASE_URL=

# Optional (defaults to http://127.0.0.1:3000)
E2E_BASE_URL=http://127.0.0.1:3000

# Optional. Needed only if /api/insights requires bearer auth.
INSIGHTS_API_TOKEN=

# Required only for nightly live AI tests (@ai-live, PW_NIGHTLY=1)
OPENAI_API_KEY=
